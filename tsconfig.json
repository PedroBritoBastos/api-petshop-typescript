{
  "compilerOptions": {
    "target": "es5",
    "strictPropertyInitialization": false,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "module": "esnext",
    "rootDir": "./src",
    "outDir": "./dist"
  }
}
